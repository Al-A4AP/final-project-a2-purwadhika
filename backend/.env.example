
DATABASE_URL=
DIRECT_URL=

JWT_SECRET=
JWT_EXPIRES_IN=7d

EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587

CLOUDINARY_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false

PORT=5000
NODE_ENV=development

# Aktifkan cron jobs (set 'true' di environment yang support persistent process)
# Di Vercel: jangan di-set (atau set 'false')
# Di local / Railway / Render: set 'true'
ENABLE_CRON=true

# CORS — untuk production Vercel, isi dengan URL frontend production (pisah koma jika lebih dari satu)
# Contoh: ALLOWED_ORIGINS=https://purwaloka.vercel.app
# Di local: biarkan kosong (otomatis pakai localhost)
ALLOWED_ORIGINS=

# URL frontend — digunakan untuk email callback links
FRONTEND_URL=http://localhost:5173