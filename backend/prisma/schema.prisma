generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                        String              @id @default(cuid())
  email                     String              @unique
  pending_email             String?
  password_hash             String
  auth_provider             AuthProvider        @default(EMAIL)
  password_set_at           DateTime?
  role                      Role                @default(USER)
  name                      String
  legal_name                String?
  phone                     String?
  ktp_number                String?
  ktp_address               String?
  domicile_address          String?
  referral_code             String?             @unique
  avatar_url                String?
  verified_at               DateTime?
  email_change_requested_at DateTime?
  deleted_at                DateTime?
  created_at                DateTime            @default(now())
  updated_at                DateTime            @default(now()) @updatedAt
  emailVerifications        EmailVerification[]
  orders                    Order[]
  passwordResets            PasswordReset[]
  tenantProperties          Property[]          @relation("TenantProperties")
  reviewReplies             ReviewReply[]
  reviews                   Review[]
  propertyCategories        PropertyCategory[]  @relation("TenantCategories")
  tenantVouchers            Voucher[]           @relation("TenantVouchers")
  userVouchers              UserVoucher[]
  referralRewardsEarned     ReferralReward[]    @relation("ReferralRewardsEarned")
  referralRewardsTriggered  ReferralReward[]    @relation("ReferralRewardsTriggered")

  @@map("users")
}

model EmailVerification {
  id           String                   @id @default(cuid())
  userId       String
  token        String                   @unique
  purpose      EmailVerificationPurpose @default(ACCOUNT_ACTIVATION)
  target_email String?
  expires_at   DateTime
  used_at      DateTime?
  created_at   DateTime                 @default(now())
  updated_at   DateTime                 @default(now()) @updatedAt
  user         User                     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, purpose])
  @@map("email_verifications")
}

model PasswordReset {
  id         String    @id @default(cuid())
  userId     String
  token      String    @unique
  expires_at DateTime
  used_at    DateTime?
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now()) @updatedAt
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_resets")
}

model PropertyCategory {
  id                  String     @id @default(cuid())
  name                String
  description         String?
  default_rental_type RentalType @default(PER_ROOM)
  tenantId            String?
  tenant              User?      @relation("TenantCategories", fields: [tenantId], references: [id])
  updated_at          DateTime   @default(now()) @updatedAt
  properties          Property[]

  @@unique([tenantId, name])
  @@map("property_categories")
}

model Property {
  id                 String           @id @default(cuid())
  tenantId           String
  categoryId         String
  name               String
  description        String
  rental_type        RentalType       @default(PER_ROOM)
  featured_image_url String?
  address            String
  city               String
  latitude           Float?
  longitude          Float?
  deleted_at         DateTime?
  created_at         DateTime         @default(now())
  amenities          String[]
  province           String?
  updated_at         DateTime         @default(now()) @updatedAt
  delete             Boolean?         @default(false)
  orders             Order[]
  category           PropertyCategory @relation(fields: [categoryId], references: [id])
  tenant             User             @relation("TenantProperties", fields: [tenantId], references: [id])
  images             PropertyImage[]
  reviews            Review[]
  rooms              Room[]

  @@index([tenantId])
  @@index([categoryId])
  @@index([city])
  @@index([deleted_at])
  @@map("properties")
}

model PropertyImage {
  id                   String   @id @default(cuid())
  propertyId           String
  image_url            String
  cloudinary_public_id String?
  order                Int      @default(0)
  created_at           DateTime @default(now())
  updated_at           DateTime @default(now()) @updatedAt
  property             Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@map("property_images")
}

model Room {
  id           String             @id @default(cuid())
  propertyId   String
  room_type    String
  base_price   Int
  description  String?
  capacity     Int
  deleted_at   DateTime?
  created_at   DateTime           @default(now())
  child_price  Int?
  quantity     Int                @default(1)
  updated_at   DateTime           @default(now()) @updatedAt
  delete       Boolean?           @default(false)
  orders       Order[]
  peakRates    PeakSeasonRate[]
  availability RoomAvailability[]
  images       RoomImage[]
  property     Property           @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@index([deleted_at])
  @@index([capacity])
  @@map("rooms")
}

model RoomAvailability {
  id           String   @id @default(cuid())
  roomId       String
  date         DateTime
  is_available Boolean  @default(true)
  created_at   DateTime @default(now())
  updated_at   DateTime @default(now()) @updatedAt
  room         Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([roomId, date])
  @@map("room_availabilities")
}

model RoomImage {
  id                   String   @id @default(cuid())
  roomId               String
  image_url            String
  cloudinary_public_id String?
  order                Int      @default(0)
  created_at           DateTime @default(now())
  updated_at           DateTime @default(now()) @updatedAt
  room                 Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@map("room_images")
}

model PeakSeasonRate {
  id          String    @id @default(cuid())
  roomId      String
  start_date  DateTime
  end_date    DateTime
  rate_type   RateType
  rate_value  Int
  description String?
  deleted_at  DateTime?
  created_at  DateTime  @default(now())
  updated_at  DateTime  @default(now()) @updatedAt
  delete      Boolean?  @default(false)
  room        Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId])
  @@map("peak_season_rates")
}

model Order {
  id                       String          @id @default(cuid())
  order_number             String          @unique
  userId                   String
  roomId                   String
  propertyId               String
  check_in_date            DateTime
  check_out_date           DateTime
  subtotal_price           Int?
  total_price              Int
  discount_amount          Int             @default(0)
  booking_for_self         Boolean         @default(true)
  guest_name               String?
  guest_legal_name         String?
  guest_phone              String?
  guest_email              String?
  guest_ktp_address        String?
  guest_ktp_number         String?
  guest_domicile_address   String?
  voucherId                String?
  referral_code            String?
  status                   OrderStatus     @default(WAITING_PAYMENT)
  payment_method           PaymentMethod   @default(MANUAL)
  payment_proof_url        String?
  payment_rejection_reason String?
  midtrans_transaction_id  String?
  payment_verified_at      DateTime?
  deleted_at               DateTime?
  canceled_at              DateTime?
  created_at               DateTime        @default(now())
  completed_at             DateTime?
  expires_at               DateTime?
  refund_completed_at      DateTime?
  refund_completed_by      String?
  check_in_reminder_sent_at DateTime?
  updated_at               DateTime        @default(now()) @updatedAt
  delete                   Boolean?        @default(false)
  property                 Property        @relation(fields: [propertyId], references: [id])
  room                     Room            @relation(fields: [roomId], references: [id])
  user                     User            @relation(fields: [userId], references: [id])
  voucher                  Voucher?        @relation(fields: [voucherId], references: [id])
  review                   Review?
  referralReward           ReferralReward?

  @@index([userId])
  @@index([roomId])
  @@index([propertyId])
  @@index([status])
  @@index([voucherId])
  @@index([referral_code])
  @@index([check_in_date, check_out_date])
  @@map("orders")
}

model Voucher {
  id              String              @id @default(cuid())
  tenantId        String
  code            String              @unique
  name            String
  description     String?
  discount_type   VoucherDiscountType @default(PERCENTAGE)
  discount_value  Int
  max_discount    Int?
  quota           Int?
  used_count      Int                 @default(0)
  starts_at       DateTime
  expires_at      DateTime
  is_active       Boolean             @default(true)
  new_user_only   Boolean             @default(false)
  deleted_at      DateTime?
  created_at      DateTime            @default(now())
  updated_at      DateTime            @default(now()) @updatedAt
  tenant          User                @relation("TenantVouchers", fields: [tenantId], references: [id])
  orders          Order[]
  referralRewards ReferralReward[]
  userVouchers    UserVoucher[]

  @@index([tenantId])
  @@index([code])
  @@index([is_active, starts_at, expires_at])
  @@map("vouchers")
}

model UserVoucher {
  id         String    @id @default(cuid())
  userId     String
  voucherId  String
  expires_at DateTime?
  used_at    DateTime?
  created_at DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  voucher    Voucher   @relation(fields: [voucherId], references: [id], onDelete: Cascade)

  @@unique([userId, voucherId])
  @@index([userId])
  @@index([voucherId])
  @@map("user_vouchers")
}

model ReferralReward {
  id             String   @id @default(cuid())
  referrerId     String
  referredUserId String
  orderId        String   @unique
  voucherId      String?
  reward_code    String
  created_at     DateTime @default(now())
  order          Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  referredUser   User     @relation("ReferralRewardsTriggered", fields: [referredUserId], references: [id])
  referrer       User     @relation("ReferralRewardsEarned", fields: [referrerId], references: [id])
  voucher        Voucher? @relation(fields: [voucherId], references: [id])

  @@index([referrerId])
  @@index([referredUserId])
  @@index([voucherId])
  @@map("referral_rewards")
}

model Review {
  id         String        @id @default(cuid())
  orderId    String        @unique
  propertyId String
  userId     String
  rating     Int
  comment    String
  deleted_at DateTime?
  created_at DateTime      @default(now())
  updated_at DateTime      @default(now()) @updatedAt
  delete     Boolean?      @default(false)
  image_url  String?
  replies    ReviewReply[]
  order      Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  property   Property      @relation(fields: [propertyId], references: [id])
  user       User          @relation(fields: [userId], references: [id])

  @@index([propertyId])
  @@index([userId])
  @@map("reviews")
}

model ReviewReply {
  id         String    @id @default(cuid())
  reviewId   String
  tenantId   String
  reply_text String
  deleted_at DateTime?
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now()) @updatedAt
  delete     Boolean?  @default(false)
  review     Review    @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  tenant     User      @relation(fields: [tenantId], references: [id])

  @@index([reviewId])
  @@index([tenantId])
  @@map("review_replies")
}

enum Role {
  USER
  TENANT
}

enum EmailVerificationPurpose {
  ACCOUNT_ACTIVATION
  EMAIL_CHANGE
}

enum AuthProvider {
  EMAIL
  GOOGLE
}

enum OrderStatus {
  WAITING_PAYMENT
  WAITING_CONFIRMATION
  PROCESSED
  CANCELLED
  COMPLETED
}

enum PaymentMethod {
  MANUAL
  MIDTRANS
}

enum RateType {
  PERCENTAGE
  NOMINAL
}

enum VoucherDiscountType {
  PERCENTAGE
  NOMINAL
  FREE_NIGHTS
}

enum RentalType {
  PER_ROOM
  WHOLE_PROPERTY
}
