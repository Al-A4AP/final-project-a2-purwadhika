generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                        String              @id @default(cuid())
  email                     String              @unique
  pending_email             String?
  password_hash             String
  auth_provider             AuthProvider        @default(EMAIL)
  password_set_at           DateTime?
  role                      Role                @default(USER)
  name                      String
  phone                     String?
  avatar_url                String?
  verified_at               DateTime?
  email_change_requested_at DateTime?
  deleted_at                DateTime?
  created_at                DateTime            @default(now())
  updated_at                DateTime            @default(now()) @updatedAt
  emailVerifications        EmailVerification[]
  orders                    Order[]
  passwordResets            PasswordReset[]
  tenantProperties          Property[]          @relation("TenantProperties")
  reviewReplies             ReviewReply[]
  reviews                   Review[]
  propertyCategories        PropertyCategory[]  @relation("TenantCategories")

  @@map("users")
}

model EmailVerification {
  id           String                   @id @default(cuid())
  userId       String
  token        String                   @unique
  purpose      EmailVerificationPurpose @default(ACCOUNT_ACTIVATION)
  target_email String?
  expires_at   DateTime
  used_at      DateTime?
  created_at   DateTime                 @default(now())
  updated_at   DateTime                 @default(now()) @updatedAt
  user         User                     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, purpose])
  @@map("email_verifications")
}

model PasswordReset {
  id         String    @id @default(cuid())
  userId     String
  token      String    @unique
  expires_at DateTime
  used_at    DateTime?
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now()) @updatedAt
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_resets")
}

model PropertyCategory {
  id         String     @id @default(cuid())
  name       String
  tenantId   String?
  tenant     User?      @relation("TenantCategories", fields: [tenantId], references: [id])
  updated_at DateTime   @default(now()) @updatedAt
  properties Property[]

  @@unique([tenantId, name])
  @@map("property_categories")
}

model Property {
  id                 String           @id @default(cuid())
  tenantId           String
  categoryId         String
  name               String
  description        String
  featured_image_url String?
  address            String
  city               String
  latitude           Float?
  longitude          Float?
  deleted_at         DateTime?
  created_at         DateTime         @default(now())
  amenities          String[]
  province           String?
  updated_at         DateTime         @default(now()) @updatedAt
  delete             Boolean?         @default(false)
  orders             Order[]
  category           PropertyCategory @relation(fields: [categoryId], references: [id])
  tenant             User             @relation("TenantProperties", fields: [tenantId], references: [id])
  images             PropertyImage[]
  reviews            Review[]
  rooms              Room[]

  @@index([tenantId])
  @@index([categoryId])
  @@index([city])
  @@index([deleted_at])
  @@map("properties")
}

model PropertyImage {
  id                   String   @id @default(cuid())
  propertyId           String
  image_url            String
  cloudinary_public_id String?
  order                Int      @default(0)
  created_at           DateTime @default(now())
  updated_at           DateTime @default(now()) @updatedAt
  property             Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@map("property_images")
}

model Room {
  id           String             @id @default(cuid())
  propertyId   String
  room_type    String
  base_price   Int
  description  String?
  capacity     Int
  deleted_at   DateTime?
  created_at   DateTime           @default(now())
  child_price  Int?
  quantity     Int                @default(1)
  updated_at   DateTime           @default(now()) @updatedAt
  delete       Boolean?           @default(false)
  orders       Order[]
  peakRates    PeakSeasonRate[]
  availability RoomAvailability[]
  images       RoomImage[]
  property     Property           @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@index([deleted_at])
  @@index([capacity])
  @@map("rooms")
}

model RoomAvailability {
  id           String   @id @default(cuid())
  roomId       String
  date         DateTime
  is_available Boolean  @default(true)
  created_at   DateTime @default(now())
  updated_at   DateTime @default(now()) @updatedAt
  room         Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([roomId, date])
  @@map("room_availabilities")
}

model RoomImage {
  id                   String   @id @default(cuid())
  roomId               String
  image_url            String
  cloudinary_public_id String?
  order                Int      @default(0)
  created_at           DateTime @default(now())
  updated_at           DateTime @default(now()) @updatedAt
  room                 Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@map("room_images")
}

model PeakSeasonRate {
  id          String    @id @default(cuid())
  roomId      String
  start_date  DateTime
  end_date    DateTime
  rate_type   RateType
  rate_value  Int
  description String?
  deleted_at  DateTime?
  created_at  DateTime  @default(now())
  updated_at  DateTime  @default(now()) @updatedAt
  delete      Boolean?  @default(false)
  room        Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId])
  @@map("peak_season_rates")
}

model Order {
  id                      String        @id @default(cuid())
  order_number            String        @unique
  userId                  String
  roomId                  String
  propertyId              String
  check_in_date           DateTime
  check_out_date          DateTime
  total_price             Int
  status                  OrderStatus   @default(WAITING_PAYMENT)
  payment_method          PaymentMethod @default(MANUAL)
  payment_proof_url       String?
  midtrans_transaction_id String?
  payment_verified_at     DateTime?
  deleted_at              DateTime?
  canceled_at             DateTime?
  created_at              DateTime      @default(now())
  completed_at            DateTime?
  expires_at              DateTime?
  updated_at              DateTime      @default(now()) @updatedAt
  delete                  Boolean?      @default(false)
  property                Property      @relation(fields: [propertyId], references: [id])
  room                    Room          @relation(fields: [roomId], references: [id])
  user                    User          @relation(fields: [userId], references: [id])
  review                  Review?

  @@index([userId])
  @@index([roomId])
  @@index([propertyId])
  @@index([status])
  @@index([check_in_date, check_out_date])
  @@map("orders")
}

model Review {
  id         String        @id @default(cuid())
  orderId    String        @unique
  propertyId String
  userId     String
  rating     Int
  comment    String
  deleted_at DateTime?
  created_at DateTime      @default(now())
  updated_at DateTime      @default(now()) @updatedAt
  delete     Boolean?      @default(false)
  image_url  String?
  replies    ReviewReply[]
  order      Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  property   Property      @relation(fields: [propertyId], references: [id])
  user       User          @relation(fields: [userId], references: [id])

  @@index([propertyId])
  @@index([userId])
  @@map("reviews")
}

model ReviewReply {
  id         String    @id @default(cuid())
  reviewId   String
  tenantId   String
  reply_text String
  deleted_at DateTime?
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now()) @updatedAt
  delete     Boolean?  @default(false)
  review     Review    @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  tenant     User      @relation(fields: [tenantId], references: [id])

  @@index([reviewId])
  @@index([tenantId])
  @@map("review_replies")
}

enum Role {
  USER
  TENANT
}

enum EmailVerificationPurpose {
  ACCOUNT_ACTIVATION
  EMAIL_CHANGE
}

enum AuthProvider {
  EMAIL
  GOOGLE
}

enum OrderStatus {
  WAITING_PAYMENT
  WAITING_CONFIRMATION
  PROCESSED
  CANCELLED
  COMPLETED
}

enum PaymentMethod {
  MANUAL
  MIDTRANS
}

enum RateType {
  PERCENTAGE
  NOMINAL
}
